{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://backy.dev/schemas/ai-frontend-contract/content-payload.schema.json",
  "title": "Backy Public Render Payload",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "status": {
      "enum": ["draft", "published", "scheduled", "archived"]
    },
    "element": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "parentId": { "type": "string", "minLength": 1 },
        "componentKey": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "controls": {
          "type": "array",
          "items": { "$ref": "#/$defs/interactiveControl" }
        },
        "fallback": { "$ref": "#/$defs/interactiveFallback" },
        "renderCapabilities": { "$ref": "#/$defs/interactiveRenderCapabilities" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/element" }
        },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "zIndex": { "type": "number" },
        "rotation": { "type": "number" },
        "visible": { "type": "boolean" },
        "locked": { "type": "boolean" },
        "props": {
          "type": "object",
          "additionalProperties": true
        },
        "styles": {
          "type": "object",
          "additionalProperties": true
        },
        "tokenRefs": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "animation": {
          "$ref": "#/$defs/animation"
        },
        "assetIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "responsive": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "element-actions.schema.json#/$defs/action"
          }
        },
        "dataBindings": {
          "type": "array",
          "items": {
            "$ref": "data-bindings.schema.json#/$defs/binding"
          }
        },
        "bindingSlots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bindingSlot"
          }
        },
        "accessibility": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string" },
            "alt": { "type": "string" },
            "role": { "type": "string" },
            "aria": {
              "type": "object",
              "additionalProperties": {
                "type": ["string", "number", "boolean"]
              }
            }
          }
        },
        "permissions": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["id", "type", "children", "props"]
    },
    "animation": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "enum": ["fadeIn", "slideIn", "scaleIn", "bounce", "rotate", "custom"] },
        "duration": { "type": "number" },
        "delay": { "type": "number" },
        "easing": { "type": "string" },
        "direction": { "enum": ["left", "right", "up", "down"] },
        "trigger": { "enum": ["load", "scroll", "hover"] },
        "scrollTrigger": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "start": { "type": "string" },
            "end": { "type": "string" },
            "scrub": { "type": "boolean" }
          }
        },
        "from": {
          "type": "object",
          "additionalProperties": true
        },
        "to": {
          "type": "object",
          "additionalProperties": true
        },
        "tokenRefs": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      },
      "required": ["type", "duration"]
    },
    "bindingSlot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "sourceKind": { "type": "string", "minLength": 1 },
        "fieldKey": { "type": "string", "minLength": 1 },
        "targetPath": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "description": { "type": "string" }
      },
      "required": ["id", "label", "targetPath"]
    },
    "interactiveControl": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "type": { "type": "string", "minLength": 1 },
        "value": {},
        "defaultValue": {},
        "options": { "type": "array" },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "required": { "type": "boolean" }
      },
      "required": ["key", "type"]
    },
    "interactiveFallback": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "title": { "type": "string" },
            "text": { "type": "string" },
            "html": { "type": "string" },
            "imageUrl": { "type": "string" },
            "alt": { "type": "string" },
            "ariaLabel": { "type": "string" }
          }
        }
      ]
    },
    "interactiveRenderCapabilities": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hydrationMode": { "type": "string", "minLength": 1 },
        "requiresSandbox": { "type": "boolean" },
        "requiresSignedBundle": { "type": "boolean" },
        "fallbackRequired": { "type": "boolean" },
        "allowedPermissions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "allowedConnectSrc": {
          "type": "array",
          "items": { "type": "string" }
        },
        "postMessageProtocol": { "type": "string" }
      },
      "required": ["hydrationMode"]
    },
    "mediaAsset": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "siteId": { "type": "string", "minLength": 1 },
        "type": { "enum": ["image", "video", "audio", "document", "font", "other"] },
        "mimeType": { "type": "string" },
        "filename": { "type": "string" },
        "originalName": { "type": "string" },
        "url": { "type": "string" },
        "thumbnailUrl": { "type": ["string", "null"] },
        "altText": { "type": ["string", "null"] },
        "caption": { "type": ["string", "null"] },
        "scope": { "enum": ["global", "page", "post"] },
        "scopeTargetId": { "type": ["string", "null"] },
        "visibility": { "enum": ["public", "private"] },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["id", "siteId", "type", "mimeType", "filename", "url", "scope", "visibility"]
    },
    "fontVariant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mediaId": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 },
        "weight": { "type": ["number", "string"] },
        "style": { "enum": ["normal", "italic", "oblique"] },
        "display": { "enum": ["auto", "block", "swap", "fallback", "optional"] },
        "fallbackStack": { "type": "string" },
        "cssFamily": { "type": "string" },
        "url": { "type": "string", "minLength": 1 },
        "mimeType": { "type": "string" },
        "sizeBytes": { "type": "integer", "minimum": 0 },
        "originalName": { "type": "string" },
        "folderId": { "type": ["string", "null"] },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "family", "url"]
    },
    "fontAsset": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mediaId": { "type": "string", "minLength": 1 },
        "family": { "type": "string", "minLength": 1 },
        "source": { "enum": ["system", "google", "uploaded", "external"] },
        "url": { "type": "string" },
        "weights": {
          "type": "array",
          "items": { "type": ["number", "string"] }
        },
        "styles": {
          "type": "array",
          "items": { "enum": ["normal", "italic", "oblique"] }
        },
        "fallbackStack": { "type": "string" },
        "display": { "enum": ["auto", "block", "swap", "fallback", "optional"] },
        "cssFamily": { "type": "string" },
        "assetIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "variants": {
          "type": "array",
          "items": { "$ref": "#/$defs/fontVariant" }
        }
      },
      "required": ["id", "family", "source"]
    },
    "contentAssetRef": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "url": { "type": "string" },
        "alt": { "type": "string" },
        "title": { "type": "string" },
        "caption": { "type": "string" },
        "visibility": { "type": "string" },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["id", "type"]
    },
    "contentDocument": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "schemaVersion": { "const": "backy.content.v1" },
        "id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["page", "post", "template", "dynamicList", "dynamicItem"] },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "locale": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "version": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "elements": {
          "type": "array",
          "items": { "$ref": "#/$defs/element" }
        },
        "themeTokenRefs": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "assets": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "media": {
              "type": "array",
              "items": { "$ref": "#/$defs/contentAssetRef" }
            },
            "fonts": {
              "type": "array",
              "items": { "$ref": "#/$defs/contentAssetRef" }
            }
          }
        },
        "interactions": {
          "type": "object",
          "additionalProperties": true
        },
        "seo": {
          "type": "object",
          "additionalProperties": true
        },
        "dataBindings": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "datasets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "bindings": {
              "type": "array",
              "items": {
                "$ref": "data-bindings.schema.json#/$defs/binding"
              }
            }
          }
        },
        "editableMap": {
          "$ref": "editable-map.schema.json"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "required": ["schemaVersion", "id", "kind", "version", "elements", "editableMap"]
    },
    "form": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 1 },
        "method": { "const": "POST" },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "key": { "type": "string", "minLength": 1 },
              "label": { "type": "string" },
              "type": { "type": "string" },
              "required": { "type": "boolean" },
              "options": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["key", "label", "type"]
          }
        }
      },
      "required": ["id", "endpoint", "method", "fields"]
    },
    "commentThread": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "targetType": { "enum": ["page", "post"] },
        "targetId": { "type": "string", "minLength": 1 },
        "endpoint": { "type": "string", "minLength": 1 },
        "moderationMode": { "enum": ["manual", "auto-approve"] },
        "count": { "type": "integer", "minimum": 0 }
      },
      "required": ["id", "targetType", "targetId", "endpoint", "moderationMode"]
    },
    "navigationItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["page", "post", "dynamicItem", "route", "url", "external"] },
        "pageId": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "path": { "type": "string", "minLength": 1 },
        "href": { "type": "string", "minLength": 1 },
        "target": { "enum": ["_self", "_blank"] },
        "status": { "$ref": "#/$defs/status" },
        "isHomepage": { "type": "boolean" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/navigationItem" }
        }
      },
      "required": ["id", "type", "label", "children"]
    },
    "navigationLayout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "header": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "variant": { "type": "string" },
            "position": { "type": "string" },
            "width": { "type": "string" },
            "showBrand": { "type": "boolean" },
            "showSearch": { "type": "boolean" },
            "showAccount": { "type": "boolean" },
            "showCart": { "type": "boolean" },
            "ctaLabel": { "type": "string" },
            "ctaHref": { "type": "string" }
          }
        },
        "footer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "variant": { "type": "string" },
            "width": { "type": "string" },
            "showSocial": { "type": "boolean" },
            "showNewsletter": { "type": "boolean" },
            "note": { "type": "string" }
          }
        }
      }
    },
    "frontendDesignContract": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "schemaVersion": { "const": "backy.frontend-design.v1" },
            "status": { "enum": ["unconfigured", "captured", "synced", "stale"] },
            "source": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "type": { "enum": ["managed-site", "custom-frontend", "manual"] },
                "label": { "type": "string" },
                "url": { "type": "string" },
                "repository": { "type": "string" },
                "branch": { "type": "string" },
                "capturedAt": { "type": "string" }
              },
              "required": ["type"]
            },
            "tokens": {
              "type": "object",
              "additionalProperties": true
            },
            "chrome": {
              "type": "object",
              "additionalProperties": true
            },
            "templates": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "type": { "enum": ["page", "blogPost", "form", "product", "collection", "section"] },
                  "name": { "type": "string", "minLength": 1 },
                  "routePattern": { "type": "string" },
                  "description": { "type": "string" },
                  "content": { "type": "object", "additionalProperties": true },
                  "bindingHints": { "type": "array" }
                },
                "required": ["id", "type", "name"]
              }
            },
            "editableMap": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "notes": { "type": "string" },
            "updatedAt": { "type": "string" }
          },
          "required": ["schemaVersion", "status", "source", "templates", "editableMap"]
        },
        { "type": "null" }
      ]
    },
    "frontendDesignProvenance": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "templateId": { "type": "string", "minLength": 1 },
            "templateName": { "type": "string" },
            "routePattern": { "type": "string" },
            "source": { "type": "object", "additionalProperties": true },
            "chrome": { "type": "object", "additionalProperties": true },
            "tokens": { "type": "object", "additionalProperties": true },
            "customCss": { "type": "string" },
            "customCSS": { "type": "string" },
            "customJs": { "type": "string" },
            "customJS": { "type": "string" },
            "contentDocument": { "type": "object", "additionalProperties": true },
            "elements": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            },
            "canvasSize": { "type": "object", "additionalProperties": true },
            "themeTokenRefs": {
              "type": "object",
              "additionalProperties": true
            },
            "assets": {
              "oneOf": [
                { "type": "array", "items": {} },
                { "type": "object", "additionalProperties": true }
              ]
            },
            "animations": {
              "oneOf": [
                {
                  "type": "array",
                  "items": { "type": "object", "additionalProperties": true }
                },
                { "type": "object", "additionalProperties": true }
              ]
            },
            "interactions": {
              "oneOf": [
                { "type": "array", "items": {} },
                { "type": "object", "additionalProperties": true }
              ]
            },
            "dataBindings": { "type": "object", "additionalProperties": true },
            "editableMap": { "type": "object", "additionalProperties": true },
            "seo": { "type": "object", "additionalProperties": true },
            "metadata": { "type": "object", "additionalProperties": true },
            "fieldKeyMap": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "bindingHints": { "type": "array" }
          },
          "required": ["templateId"]
        },
        { "type": "null" }
      ]
    },
    "productDesignReadiness": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "schemaVersion": { "const": "backy.product-design-readiness.v1" },
        "status": { "enum": ["ready", "attention", "blocked"] },
        "templateId": { "type": ["string", "null"] },
        "hasDesign": { "type": "boolean" },
        "hasContentDocument": { "type": "boolean" },
        "hasEditableMap": { "type": "boolean" },
        "hasDataBindings": { "type": "boolean" },
        "counts": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "elements": { "type": "integer", "minimum": 0 },
            "animations": { "type": "integer", "minimum": 0 },
            "assets": { "type": "integer", "minimum": 0 },
            "bindingHints": { "type": "integer", "minimum": 0 }
          },
          "required": ["elements", "animations", "assets", "bindingHints"]
        },
        "missing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "detail": { "type": "string" },
        "nextAction": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "secretHandling": { "type": "string" }
      },
      "required": ["schemaVersion", "status", "templateId", "hasDesign", "hasContentDocument", "hasEditableMap", "hasDataBindings", "counts", "missing", "detail", "nextAction", "evidence", "secretHandling"]
    },
    "renderFrontendDesign": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "site": { "$ref": "#/$defs/frontendDesignContract" },
        "content": { "$ref": "#/$defs/frontendDesignProvenance" }
      },
      "required": ["site", "content"]
    }
  },
  "properties": {
    "success": { "const": true },
    "requestId": { "type": "string", "minLength": 1 },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "site": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "slug": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "locale": { "type": "string", "minLength": 2 },
            "status": { "$ref": "#/$defs/status" },
            "assetsBaseUrl": { "type": "string" },
            "themeTokens": { "$ref": "theme-tokens.schema.json" }
          },
          "required": ["id", "slug", "name", "locale", "status", "themeTokens"]
        },
        "route": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "enum": ["page", "post", "dynamicList", "dynamicItem", "redirect", "notFound", "gone"] },
            "path": { "type": "string" },
            "status": { "$ref": "#/$defs/status" },
            "canonical": { "type": "string" },
            "params": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "dataset": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": true
                },
                { "type": "null" }
              ]
            },
            "resource": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "designReadiness": { "$ref": "#/$defs/productDesignReadiness" }
              }
            }
          },
          "required": ["type", "path", "status", "canonical"]
        },
        "navigation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary": {
              "type": "array",
              "items": { "$ref": "#/$defs/navigationItem" }
            },
            "footer": {
              "type": "array",
              "items": { "$ref": "#/$defs/navigationItem" }
            },
            "layout": {
              "$ref": "#/$defs/navigationLayout"
            }
          },
          "required": ["primary"]
        },
        "frontendDesign": {
          "$ref": "#/$defs/renderFrontendDesign"
        },
        "content": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "schemaVersion": { "const": "backy.content.v1" },
            "id": { "type": "string", "minLength": 1 },
            "kind": { "enum": ["page", "post", "template", "dynamicList", "dynamicItem"] },
            "title": { "type": "string" },
            "locale": { "type": "string" },
            "version": { "type": "string" },
            "elements": {
              "type": "array",
              "items": { "$ref": "#/$defs/element" }
            },
            "canvasSize": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "width": { "type": "number" },
                "height": { "type": "number" }
              }
            },
            "customCSS": { "type": "string" },
            "customJS": { "type": "string" },
            "contentDocument": {
