{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://backy.dev/schemas/ai-frontend-contract/frontend-manifest.schema.json",
  "title": "Backy AI Frontend Manifest",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "success": { "const": true },
    "requestId": { "type": "string", "minLength": 1 },
    "data": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "schemaVersion": { "const": "backy.frontend-manifest.v1" },
        "generatedAt": { "type": "string" },
        "site": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "slug": { "type": "string", "minLength": 1 },
            "name": { "type": "string", "minLength": 1 },
            "status": { "type": "string" },
            "themeTokens": { "type": "object" },
            "frontendDesign": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "schemaVersion": { "const": "backy.frontend-design.v1" },
                    "status": { "enum": ["unconfigured", "captured", "synced", "stale"] },
                    "source": {
                      "type": "object",
                      "additionalProperties": true,
                      "properties": {
                        "type": { "enum": ["managed-site", "custom-frontend", "manual"] },
                        "label": { "type": "string" },
                        "url": { "type": "string" },
                        "repository": { "type": "string" },
                        "branch": { "type": "string" },
                        "capturedAt": { "type": "string" }
                      },
                      "required": ["type"]
                    },
                    "tokens": {
                      "type": "object",
                      "additionalProperties": true,
                      "properties": {
                        "colors": { "type": "object", "additionalProperties": { "type": "string" } },
                        "fonts": { "type": "object", "additionalProperties": { "type": "string" } },
                        "spacing": { "type": "object", "additionalProperties": true },
                        "radii": { "type": "object", "additionalProperties": true },
                        "shadows": { "type": "object", "additionalProperties": true },
                        "customCss": { "type": "string" }
                      }
                    },
                    "chrome": {
                      "type": "object",
                      "additionalProperties": true,
                      "properties": {
                        "header": { "type": "object", "additionalProperties": true },
                        "navigation": { "type": "object", "additionalProperties": true },
                        "footer": { "type": "object", "additionalProperties": true }
                      }
                    },
                    "templates": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "id": { "type": "string", "minLength": 1 },
                          "type": { "enum": ["page", "blogPost", "form", "product", "collection", "section"] },
                          "name": { "type": "string", "minLength": 1 },
                          "routePattern": { "type": "string" },
                          "description": { "type": "string" },
                          "canvasSize": {
                            "type": "object",
                            "additionalProperties": true,
                            "properties": {
                              "width": { "type": "number" },
                              "height": { "type": "number" }
                            }
                          },
                          "content": { "type": "object", "additionalProperties": true },
                          "bindingHints": { "type": "array" }
                        },
                        "required": ["id", "type", "name"]
                      }
                    },
                    "editableMap": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "selector": { "type": "string" },
                          "elementId": { "type": "string" },
                          "role": { "type": "string" },
                          "binding": { "type": "string" },
                          "fields": { "type": "array", "items": { "type": "string" } }
                        }
                      }
                    },
                    "notes": { "type": "string" },
                    "updatedAt": { "type": "string" }
                  },
                  "required": ["schemaVersion", "status", "source", "templates", "editableMap"]
                },
                { "type": "null" }
              ]
            },
            "commentPolicy": { "type": "object" }
          },
          "required": ["id", "slug", "name", "status", "themeTokens"]
        },
        "contract": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "version": { "const": "backy.ai-frontend.v1" },
            "schemas": {
              "type": "object",
              "additionalProperties": { "type": "string" },
              "required": ["manifest", "renderPayload", "themeTokens", "elementActions", "dataBindings", "editableMap"]
            }
          },
          "required": ["version", "schemas"]
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": { "type": "boolean" },
          "required": [
            "routeResolve",
            "renderPayload",
            "openApi",
            "navigation",
            "mediaLibrary",
            "forms",
            "collectionSchemas",
            "collectionRecords",
            "reusableSections",
            "dynamicListRoutes",
            "dynamicItemRoutes",
            "redirectRoutes",
            "frontendDesignContract"
          ]
        },
        "endpoints": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "required": ["site", "manifest", "openapi", "resolve", "render", "navigation", "frontendDesign", "media", "pages", "blog", "collections", "reusableSections", "forms"]
        },
        "routePatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "pattern": { "type": "string", "minLength": 1 },
              "resolveUrl": { "type": "string", "minLength": 1 },
              "renderUrl": { "type": "string", "minLength": 1 },
              "frontendDesign": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "templateId": { "type": "string", "minLength": 1 },
                  "templateName": { "type": "string" },
                  "routePattern": { "type": "string" },
                  "source": { "type": "object", "additionalProperties": true },
                  "chrome": { "type": "object", "additionalProperties": true },
                  "tokens": { "type": "object", "additionalProperties": true },
                  "customCss": { "type": "string" },
                  "bindingHints": { "type": "array" }
                },
                "required": ["templateId"]
              }
            },
            "required": ["type", "pattern", "resolveUrl", "renderUrl"]
          }
        },
        "modules": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "routing": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "supportedRouteTypes": {
                  "type": "array",
                  "items": {
                    "enum": ["page", "post", "dynamicList", "dynamicItem", "redirect", "gone", "notFound"]
                  }
                },
                "redirectRules": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "count": { "type": "number", "minimum": 0 },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "id": { "type": "string" },
                          "type": { "enum": ["redirect", "gone"] },
                          "from": { "type": "string", "minLength": 1 },
                          "to": { "type": ["string", "null"] },
                          "statusCode": { "enum": [301, 302, 307, 308, 410] },
                          "resolveUrl": { "type": "string", "minLength": 1 }
                        },
                        "required": ["type", "from", "statusCode", "resolveUrl"]
                      }
                    }
                  },
                  "required": ["count", "items"]
                }
              },
              "required": ["supportedRouteTypes", "redirectRules"]
            },
            "pages": {
              "type": "object",
              "properties": {
                "count": { "type": "number", "minimum": 0 },
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "title": { "type": "string" },
                      "slug": { "type": "string", "minLength": 1 },
                      "path": { "type": "string", "minLength": 1 },
                      "status": { "type": "string" },
                      "renderUrl": { "type": "string", "minLength": 1 },
                      "frontendDesign": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "templateId": { "type": "string", "minLength": 1 },
                          "templateName": { "type": "string" },
                          "routePattern": { "type": "string" },
                          "source": { "type": "object", "additionalProperties": true },
                          "chrome": { "type": "object", "additionalProperties": true },
                          "tokens": { "type": "object", "additionalProperties": true },
                          "customCss": { "type": "string" },
                          "bindingHints": { "type": "array" }
                        },
                        "required": ["templateId"]
                      }
                    }
                  }
                }
              },
              "required": ["count", "items"]
            },
            "blog": {
              "type": "object",
              "properties": {
                "count": { "type": "number", "minimum": 0 },
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "title": { "type": "string" },
                      "slug": { "type": "string", "minLength": 1 },
                      "path": { "type": "string", "minLength": 1 },
                      "status": { "type": "string" },
                      "renderUrl": { "type": "string", "minLength": 1 },
                      "frontendDesign": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "templateId": { "type": "string", "minLength": 1 },
                          "templateName": { "type": "string" },
                          "routePattern": { "type": "string" },
                          "source": { "type": "object", "additionalProperties": true },
                          "chrome": { "type": "object", "additionalProperties": true },
                          "tokens": { "type": "object", "additionalProperties": true },
                          "customCss": { "type": "string" },
                          "bindingHints": { "type": "array" }
                        },
                        "required": ["templateId"]
                      }
                    }
                  }
                },
                "feeds": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "title": { "type": "string" },
                      "format": { "type": "string" },
                      "version": { "type": "string" },
                      "rel": { "type": "string" },
                      "contentType": { "type": "string" },
                      "endpoint": { "type": "string", "minLength": 1 },
                      "hostedPath": { "type": "string", "minLength": 1 },
                      "schemaVersion": { "type": "string" },
                      "scope": { "type": "string" },
                      "visibility": { "type": "string" },
                      "cache": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "scope": { "type": "string" },
                          "etag": { "type": "boolean" },
                          "revisionHeader": { "type": "string" }
                        }
                      },
                      "limits": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "queryParam": { "type": "string" },
                          "default": { "type": "number" },
                          "min": { "type": "number" },
                          "max": { "type": "number" }
                        }
                      }
                    },
                    "required": ["id", "format", "contentType", "endpoint"]
                  }
                },
                "categories": { "type": "array" },
                "tags": { "type": "array" },
                "authors": { "type": "array" }
              },
              "required": ["count", "categories", "tags", "authors"]
            },
            "collections": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "slug": { "type": "string", "minLength": 1 },
                  "name": { "type": "string", "minLength": 1 },
                  "fields": { "type": "array" },
                  "recordsUrl": { "type": "string", "minLength": 1 },
                  "listRoutePattern": { "type": "string", "minLength": 1 },
                  "dynamicListRoutePattern": { "type": "string", "minLength": 1 },
                  "dynamicListRouteResolveUrl": { "type": "string", "minLength": 1 },
                  "dynamicListRouteRenderUrl": { "type": "string", "minLength": 1 },
                  "routePattern": { "type": "string", "minLength": 1 },
                  "dynamicRoutePattern": { "type": "string", "minLength": 1 },
                  "dynamicRouteResolveUrl": { "type": "string", "minLength": 1 },
                  "dynamicRouteRenderUrl": { "type": "string", "minLength": 1 },
                  "frontendDesign": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "templateId": { "type": "string", "minLength": 1 },
                      "templateName": { "type": "string" },
                      "routePattern": { "type": "string" },
                      "source": { "type": "object", "additionalProperties": true },
                      "chrome": { "type": "object", "additionalProperties": true },
                      "tokens": { "type": "object", "additionalProperties": true },
                      "customCss": { "type": "string" },
                      "bindingHints": { "type": "array" }
                    },
                    "required": ["templateId"]
                  }
                },
                "required": ["id", "slug", "name", "fields", "recordsUrl", "dynamicListRoutePattern", "dynamicRoutePattern"]
              }
            },
            "forms": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "id": { "type": "string", "minLength": 1 },
                  "title": { "type": "string" },
                  "active": { "type": "boolean" },
                  "fields": { "type": "array" },
                  "submitUrl": { "type": "string", "minLength": 1 }
                },
                "required": ["id", "active", "fields", "submitUrl"]
              }
            },
            "reusableSections": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "count": { "type": "number", "minimum": 0 },
                "listUrl": { "type": "string", "minLength": 1 },
                "categories": { "type": "array" },
                "tags": { "type": "array" },
                "items": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true,
                    "properties": {
                      "id": { "type": "string", "minLength": 1 },
                      "slug": { "type": "string", "minLength": 1 },
                      "name": { "type": "string", "minLength": 1 },
                      "detailUrl": { "type": "string", "minLength": 1 },
                      "elementCount": { "type": "number", "minimum": 0 },
                      "frontendDesign": {
                        "type": "object",
                        "additionalProperties": true,
                        "properties": {
                          "templateId": { "type": "string", "minLength": 1 },
                          "templateName": { "type": "string" },
                          "routePattern": { "type": "string" },
                          "source": { "type": "object", "additionalProperties": true },
                          "chrome": { "type": "object", "additionalProperties": true },
                          "tokens": { "type": "object", "additionalProperties": true },
                          "customCss": { "type": "string" },
                          "bindingHints": { "type": "array" }
                        },
                        "required": ["templateId"]
                      }
                    },
                    "required": ["id", "slug", "name", "detailUrl", "elementCount"]
                  }
                }
              },
              "required": ["count", "listUrl", "categories", "tags", "items"]
            },
            "media": {
              "type": "object",
              "properties": {
                "count": { "type": "number", "minimum": 0 },
                "publicCount": { "type": "number", "minimum": 0 },
                "fontCount": { "type": "number", "minimum": 0 },
                "types": { "type": "array" },
                "listUrl": { "type": "string", "minLength": 1 }
              },
              "required": ["count", "publicCount", "fontCount", "types", "listUrl"]
            }
          },
          "required": ["routing", "pages", "blog", "collections", "forms", "reusableSections", "media"]
        },
        "navigation": { "type": "object" }
      },
      "required": [
        "schemaVersion",
        "site",
        "contract",
        "capabilities",
        "endpoints",
        "routePatterns",
        "modules",
        "navigation"
      ]
    }
  },
  "required": ["success", "requestId", "data"]
}
