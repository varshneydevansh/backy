{
    "name": "@backy/public",
    "version": "1.0.0",
    "description": "Backy CMS Public Site Renderer - SSR page rendering",
    "private": true,
    "scripts": {
        "dev": "next dev -p 3001",
        "build": "next build",
        "start": "next start -p 3001",
        "lint": "next lint",
        "typecheck": "tsc --noEmit",
        "test:ai-contract-examples": "node scripts/validate-ai-contract-examples.mjs",
        "test:preview-contract": "node scripts/preview-contract-smoke.mjs",
        "test:frontend-contract": "node scripts/frontend-contract-smoke.mjs",
        "test:template-registry": "tsx --tsconfig tsconfig.json scripts/template-registry-smoke.ts",
        "test:blog-api": "npm run test:preview-contract && npm run test:admin-contract && npm run test:public-security",
        "test:admin-auth": "node scripts/admin-auth-smoke.mjs",
        "test:admin-site-scope": "node scripts/admin-site-scope-smoke.mjs",
        "test:admin-site-scope:repository": "tsx --tsconfig tsconfig.json scripts/admin-site-scope-repository-smoke.mts",
        "test:admin-rbac-coverage": "node scripts/admin-rbac-coverage-smoke.mjs",
        "test:settings-admin-contract": "node scripts/settings-admin-contract-smoke.mjs",
        "test:admin-auth-supabase": "tsx scripts/admin-supabase-auth-smoke.ts",
        "test:admin-auth-supabase-route": "node scripts/admin-supabase-login-route-smoke.mjs",
        "test:admin-auth-production-policy": "tsx scripts/admin-auth-production-policy-smoke.ts",
    "test:form-captcha": "tsx scripts/form-captcha-smoke.ts",
    "test:media-quota": "node scripts/media-quota-smoke.mjs",
    "test:media-upload-policy": "tsx --tsconfig tsconfig.json scripts/media-upload-policy-smoke.ts",
    "test:media-upload-contract": "node scripts/media-upload-contract-smoke.mjs",
    "test:media-reference-collector": "tsx --tsconfig tsconfig.json scripts/media-reference-collector-smoke.ts",
    "test:sdk-postgres-preflight-contract": "node scripts/sdk-postgres-preflight-contract-smoke.mjs",
    "test:media-safety": "tsx scripts/media-safety-provider-smoke.ts",
        "test:media-scope": "tsx scripts/media-scope-smoke.ts",
        "test:media-secret-manager": "node scripts/media-secret-manager-smoke.mjs",
        "test:site-webhook-delivery": "tsx --tsconfig tsconfig.json scripts/site-webhook-delivery-smoke.ts",
        "test:interactive-sandbox-security": "node scripts/interactive-sandbox-security-smoke.mjs",
        "test:site-discovery-rate-limit": "node scripts/site-discovery-rate-limit-smoke.mjs",
        "test:commerce-webhook": "tsx scripts/commerce-webhook-idempotency-smoke.ts",
        "test:commerce-webhook-secret": "tsx scripts/commerce-webhook-secret-smoke.ts",
        "test:repository-runtime": "tsx scripts/repository-runtime-smoke.ts",
        "test:page-renderer": "tsx scripts/page-renderer-rich-text-smoke.tsx",
        "test:hosted-responsive": "node scripts/hosted-responsive-smoke.mjs",
        "test:admin-contract": "node scripts/admin-contract-smoke.mjs",
        "test:admin-contract-source": "BACKY_ADMIN_CONTRACT_SOURCE_GUARD=1 node scripts/admin-contract-smoke.mjs",
        "test:localized-routes": "tsx --tsconfig tsconfig.json scripts/localized-route-smoke.ts",
        "test:public-security": "node scripts/public-security-regression-smoke.mjs"
    },
    "dependencies": {
        "@backy-cms/core": "*",
        "@backy/db": "*",
        "@backy/storage": "*",
        "gsap": "^3.12.0",
        "next": "^16.1.6",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "ajv": "^8.20.0",
        "tsx": "^4.21.0",
        "typescript": "^5.3.0"
    }
}
