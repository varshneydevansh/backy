# Backy runtime mode
# Use demo for local in-memory fixtures, database for persistent CMS data.
BACKY_DATA_MODE=demo
# BACKY_DATA_MODE=database

# Database
# Supported types: postgres, mysql, sqlite.
BACKY_DATABASE_TYPE=postgres
BACKY_DATABASE_URL=postgres://postgres:postgres@localhost:5432/backy
BACKY_DATABASE_LOGGING=false
# SQLite alternative for database mode:
# BACKY_DATABASE_TYPE=sqlite
# BACKY_DATABASE_PATH=./backy.db
# Legacy alias still supported by tooling:
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/backy

# Admin access and local demo credentials
BACKY_ADMIN_API_KEY=dev-admin-key-change-me
BACKY_ADMIN_SECRET_KEY=dev-admin-secret-change-me
BACKY_ADMIN_DEMO_PASSWORD=admin123
BACKY_EDITOR_DEMO_PASSWORD=editor123
BACKY_EXPOSE_LOCAL_RECOVERY_TOKEN=false

# Public/admin app URLs used by the local Vite admin app.
# VITE_BACKY_ADMIN_API_KEY is a local/demo fallback only. Do not configure it
# on the protected backy-admin Vercel project.
VITE_BACKY_PUBLIC_API_BASE_URL=http://localhost:3001/api
VITE_BACKY_ADMIN_API_BASE_URL=http://localhost:3001/api/admin
VITE_BACKY_ADMIN_API_KEY=dev-admin-key-change-me

# Public app and site defaults
BACKY_PUBLIC_APP_URL=http://localhost:3001
BACKY_DEFAULT_TEAM_ID=
BACKY_TEAM_ID=
APP_URL=http://localhost:3001
SITE_NAME=Backy CMS
ADMIN_EMAIL=admin@example.com

# Supabase project and storage metadata
BACKY_SUPABASE_URL=
BACKY_SUPABASE_ANON_KEY=
BACKY_SUPABASE_SERVICE_ROLE_KEY=
BACKY_SUPABASE_STORAGE_BUCKET=backy-media

# Media storage
# Supported providers: local, supabase, s3.
BACKY_STORAGE_PROVIDER=local
BACKY_LOCAL_UPLOADS_DIR=./uploads
BACKY_LOCAL_PUBLIC_URL=/uploads
BACKY_MEDIA_SIGNING_SECRET=dev-media-signing-secret-change-me
BACKY_SITE_MEDIA_QUOTA_BYTES=1073741824

# S3-compatible media storage
BACKY_S3_BUCKET=
BACKY_S3_REGION=
BACKY_S3_ACCESS_KEY_ID=
BACKY_S3_SECRET_ACCESS_KEY=
BACKY_S3_ENDPOINT=
BACKY_S3_PUBLIC_URL=
BACKY_S3_FORCE_PATH_STYLE=false

# Media safety scanner
# Use none locally, http for an external scanner, or clamav for clamd.
BACKY_MEDIA_SCAN_PROVIDER=none
BACKY_MEDIA_SCAN_ENDPOINT=
BACKY_MEDIA_SCAN_API_KEY=
BACKY_MEDIA_SCAN_HOST=127.0.0.1
BACKY_MEDIA_SCAN_PORT=3310
BACKY_MEDIA_SCAN_TIMEOUT_MS=5000
BACKY_MEDIA_SCAN_FAIL_OPEN=false

# Forms, comments, and notifications
BACKY_FORM_CAPTCHA_PROVIDER=none
BACKY_FORM_CAPTCHA_SECRET_KEY=
BACKY_FORM_CAPTCHA_TIMEOUT_MS=5000
BACKY_FORM_CAPTCHA_MOCK_TOKEN=backy-captcha-pass
BACKY_COMMENT_NOTIFICATION_EMAIL=
BACKY_NOTIFICATION_EMAIL_TO=
BACKY_ADMIN_NOTIFICATION_EMAIL=

# Auth recovery rate limits
BACKY_AUTH_RECOVERY_RATE_LIMIT_MAX=5
BACKY_AUTH_RECOVERY_CLIENT_RATE_LIMIT_MAX=25
BACKY_AUTH_RECOVERY_RATE_LIMIT_WINDOW_MS=900000

# Vercel deployment metadata
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
VERCEL_TOKEN=
VERCEL_ENV=development
VERCEL_URL=
# Backy-prefixed aliases:
BACKY_VERCEL_PROJECT_ID=
BACKY_VERCEL_TEAM_ID=
BACKY_VERCEL_TOKEN=

# Vercel project env: backy-public (Next.js public API/render app)
# Set these in the apps/public Vercel project, not in the Vite admin shell.
# BACKY_DATA_MODE=database
# BACKY_DATABASE_URL=postgres://...
# DATABASE_URL=postgres://...
# POSTGRES_URL=postgres://...
# POSTGRES_PRISMA_URL=postgres://...
# BACKY_ADMIN_API_KEY=<server-only-admin-api-key>
# BACKY_ADMIN_SECRET_KEY=<server-only-admin-session-secret>
# BACKY_OWNER_BOOTSTRAP_TOKEN=<one-time-server-only-first-owner-token>
# CRON_SECRET=<same-server-only-admin-or-cron-secret>
# NEXT_PUBLIC_BACKY_ADMIN_APP_URL=https://admin.example.com
# BACKY_CORS_ALLOWED_ORIGINS=https://www.example.com,https://blog.example.com
# BACKY_STORAGE_PROVIDER=supabase
# BACKY_SUPABASE_URL=https://...
# BACKY_SUPABASE_ANON_KEY=<public-supabase-anon-key-if-used>
# BACKY_SUPABASE_SERVICE_ROLE_KEY=<server-only-service-role-key>

# Vercel project env: backy-admin (protected Vite editor shell)
# This project should receive only public/admin API base URLs.
# VITE_BACKY_PUBLIC_API_BASE_URL=https://content.example.com/api
# VITE_BACKY_ADMIN_API_BASE_URL=https://content.example.com/api/admin
# Forbidden here: BACKY_DATABASE_URL, DATABASE_URL, CRON_SECRET,
# BACKY_ADMIN_API_KEY, BACKY_ADMIN_SECRET_KEY, provider/storage secrets,
# and any production VITE_BACKY_ADMIN_API_KEY.

# Vercel project env: custom website frontend
# BACKY_PUBLIC_API_BASE_URL=https://content.example.com/api
# BACKY_SITE_ID=site-demo
# BACKY_SITE_PUBLIC_HOST=www.example.com

# Stripe billing placeholders
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Smoke/test helpers
BACKY_PUBLIC_CONTRACT_BASE_URL=http://localhost:3001
BACKY_PUBLIC_API_BASE_URL=http://localhost:3001
BACKY_ADMIN_BASE_URL=http://localhost:5173
BACKY_SDK_BASE_URL=http://localhost:3001
BACKY_SDK_SITE_IDENTIFIER=site-demo
BACKY_SDK_SKIP_WRITE_SMOKE=0
