{
  "name": "@backy-cms/core",
  "version": "1.0.0",
  "description": "Core types, constants, and utilities for Backy CMS",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./content-contract": {
      "types": "./dist/content-contract.d.ts",
      "import": "./dist/content-contract.mjs",
      "require": "./dist/content-contract.js"
    },
    "./content-migrations": {
      "types": "./dist/content-migrations.d.ts",
      "import": "./dist/content-migrations.mjs",
      "require": "./dist/content-migrations.js"
    },
    "./code-highlight": {
      "types": "./dist/code-highlight.d.ts",
      "import": "./dist/code-highlight.mjs",
      "require": "./dist/code-highlight.js"
    },
    "./repositories": {
      "types": "./dist/repositories.d.ts",
      "import": "./dist/repositories.mjs",
      "require": "./dist/repositories.js"
    },
    "./theme-tokens": {
      "types": "./dist/theme-tokens.d.ts",
      "import": "./dist/theme-tokens.mjs",
      "require": "./dist/theme-tokens.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.mjs",
      "require": "./dist/types/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/content-contract.ts src/content-migrations.ts src/code-highlight.ts src/repositories.ts src/theme-tokens.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/content-contract.ts src/content-migrations.ts src/code-highlight.ts src/repositories.ts src/theme-tokens.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "test:content-contract": "npm run build && node scripts/content-contract-smoke.mjs && node scripts/content-migrations-smoke.mjs",
    "test:repositories": "npm run build && node scripts/repository-contract-smoke.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "cms",
    "types",
    "core"
  ],
  "author": "Backy CMS Team",
  "license": "MIT"
}
