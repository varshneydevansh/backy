{
  "name": "@backy/sdk-js",
  "version": "0.1.0",
  "description": "TypeScript client for Backy public frontend APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc --noEmit",
    "test:smoke": "node scripts/smoke.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "backy",
    "cms",
    "sdk",
    "frontend",
    "headless"
  ],
  "author": "Backy Team",
  "license": "MIT"
}
