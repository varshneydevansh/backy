{
  "name": "backy",
  "version": "1.0.0",
  "description": "Backy - Free, open-source visual website builder and CMS backend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "dev:smoke:admin": "npm run dev:smoke:admin --workspace @backy-cms/admin",
    "dev:smoke:public": "npm run dev:smoke:public --workspace @backy-cms/admin",
    "test:smoke:admin": "npm run test:smoke:admin --workspace @backy-cms/admin",
    "test:smoke:public": "npm run test:smoke:public --workspace @backy-cms/admin",
    "test:smoke:blog-api": "npm run test:blog-api --workspace @backy/public",
    "test:smoke:sdk": "npm run test:smoke --workspace @backy/sdk-js",
    "test:smoke:storage": "npm run test:smoke --workspace @backy/storage",
    "test:smoke:all": "npm run test:smoke:admin && npm run test:smoke:public && npm run test:smoke:sdk && npm run test:smoke:storage",
    "ci:blog-api-contract": "node scripts/blog-api-contract-ci.mjs",
    "test:frontend-contract-types": "npm run test:frontend-contract --workspace @backy/public && npm run test:generated-types --workspace @backy/sdk-js",
    "test:admin-contract-source": "npm run test:admin-contract-source --workspace @backy/public",
    "test:admin-rbac-coverage": "npm run test:admin-rbac-coverage --workspace @backy/public",
    "test:settings-admin-contract": "npm run test:settings-admin-contract --workspace @backy/public",
    "test:settings-provider-certification-preflight-contract": "node scripts/settings-provider-certification-preflight-contract-smoke.mjs",
    "test:commerce-provider-certification-preflight-contract": "node scripts/commerce-provider-certification-preflight-contract-smoke.mjs",
    "test:release-certification-preflight-contract": "node scripts/backy-release-certification-preflight-contract-smoke.mjs",
    "test:release-certification-doctor-contract": "node scripts/backy-release-certification-doctor-contract-smoke.mjs",
    "test:vercel-release-config": "node scripts/vercel-release-config-smoke.mjs",
    "test:vercel-preview-readiness": "node scripts/vercel-preview-readiness-smoke.mjs",
    "doctor:release-certification": "node scripts/backy-release-certification-doctor.mjs",
    "test:sdk-postgres-preflight-contract": "npm run test:sdk-postgres-preflight-contract --workspace @backy/public",
    "test:forms-postgres-preflight-contract": "npm run test:forms-postgres-preflight-contract --workspace @backy/db",
    "test:forms-postgres-disposable-guard": "npm run test:forms-postgres-disposable-guard --workspace @backy/db",
    "test:sdk-postgres-disposable-guard": "node scripts/sdk-postgres-disposable-guard-smoke.mjs",
    "test:settings-source-only": "BACKY_SETTINGS_SOURCE_ONLY=1 npm run test:settings --workspace @backy-cms/admin",
    "test:commerce-source-only": "BACKY_COMMERCE_SOURCE_ONLY=1 npm run test:commerce --workspace @backy-cms/admin",
    "test:orders-source-only": "BACKY_ORDERS_SOURCE_ONLY=1 npm run test:orders --workspace @backy-cms/admin",
    "test:provider-source-only": "npm run test:settings-source-only && npm run test:commerce-source-only && npm run test:orders-source-only",
    "test:partial-gate-preflights": "npm run test:forms-postgres-preflight-contract && npm run test:forms-postgres-disposable-guard && npm run test:sdk-postgres-preflight-contract && npm run test:sdk-postgres-disposable-guard && npm run test:admin-contract-source && npm run test:admin-rbac-coverage && npm run test:vercel-release-config && npm run test:vercel-preview-readiness && npm run test:provider-source-only && npm run test:settings-provider-certification-preflight-contract && npm run test:commerce-provider-certification-preflight-contract && npm run test:release-certification-doctor-contract && npm run test:release-certification-preflight-contract",
    "ci:sdk-smoke": "npm run test:sdk-postgres-preflight-contract && node scripts/sdk-smoke-ci.mjs",
    "ci:sdk-postgres-smoke": "npm run test:sdk-postgres-preflight-contract && npm run test:sdk-postgres-disposable-guard && BACKY_SDK_REQUIRE_DATABASE=1 node scripts/sdk-smoke-ci.mjs",
    "ci:commerce-provider-smoke": "node scripts/commerce-provider-smoke-ci.mjs",
    "ci:commerce-provider-certification": "node scripts/commerce-provider-certification-ci.mjs",
    "ci:forms-postgres": "npm run test:forms-postgres-preflight-contract && npm run test:forms-postgres-disposable-guard && npm run test:forms-postgres --workspace @backy/db",
    "ci:settings-provider-certification": "node scripts/settings-provider-certification-ci.mjs",
    "ci:provider-artifact-admission": "node scripts/provider-artifact-admission.mjs",
    "smoke": "npm run test:smoke:all",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:generate": "cd packages/db && npx drizzle-kit generate",
    "db:migrate": "cd packages/db && npx drizzle-kit migrate",
    "db:studio": "cd packages/db && npx drizzle-kit studio",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@libsql/client": "^0.4.0",
    "@types/node": "^20.0.0",
    "@udecode/plate-paragraph": "latest",
    "postgres": "^3.4.9",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.0.0",
  "author": "Backy CMS Team (Built by Kimi 2.5)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/backy-cms/backy"
  },
  "keywords": [
    "cms",
    "website-builder",
    "visual-editor",
    "open-source",
    "free",
    "wix-alternative",
    "react",
    "typescript",
    "supabase"
  ]
}
